[flake8]
# Maximum line length (Black's default)
max-line-length = 88

# Ignore specific error codes for Black compatibility
ignore = 
    E203,  # whitespace before ':'
    E266,  # too many leading '#' for block comment
    E501,  # line too long (82 > 79 characters)
    E731,  # do not assign a lambda expression, use a def
    W503,  # line break before binary operator
    W504,  # line break after binary operator

# Exclude directories
exclude = 
    .git,
    __pycache__,
    .venv,
    venv,
    .pytest_cache,
    .mypy_cache,
    build,
    dist,
    *.egg-info,
    ai_app.egg-info

# Per-file ignores
per-file-ignores =
    __init__.py:F401  # Allow unused imports in __init__.py
    tests/*:S101     # Allow assert statements in tests

# Select specific error codes to check
select = 
    B,    # flake8-bugbear
    C,    # pycodestyle
    E,    # pycodestyle
    F,    # pyflakes
    I,    # isort
    W,    # pycodestyle
    YTT,  # flake8-2020

# Show source code for each error
show-source = True

# Show error code for each error
show-error-codes = True

# Maximum complexity for functions
max-complexity = 10

# Import-related settings
import-order-style = google
application-import-names = app